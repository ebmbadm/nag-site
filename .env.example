# Runtime environment for the NAG · NOVIK site (server-side only; not needed at build).
# Copy to .env and fill in. Pass to the container via `--env-file .env`.

# Supabase — backs the contact-form server action (app/actions/submit-inquiry.ts)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Notifications on new inquiry (optional — lib/notifications.ts skips if unset)
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
